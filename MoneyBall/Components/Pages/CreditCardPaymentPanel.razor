@using MoneyBall.Data.Entities
@using MoneyBall.Services
@inject TransactionService TransactionService

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Pay Statement</h5>

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-2">
                <label>Pay from</label>
                <InputSelect class="form-control" @bind-Value="_model.FromAccountId">
                    <option value="">-- Select an account --</option>
                    @foreach (var account in OtherAccounts)
                    {
                        <option value="@account.Id">@account.Name</option>
                    }
                </InputSelect>
                @if (_fromAccountError is not null)
                {
                    <div class="text-danger">@_fromAccountError</div>
                }
            </div>

            <div class="mb-2">
                <label>Amount</label>
                <InputNumber class="form-control" @bind-Value="_model.Amount" />
            </div>

            <div class="mb-2">
                <label>Description</label>
                <InputText class="form-control" @bind-Value="_model.Description" />
            </div>

            <div class="mb-2">
                <label>Date</label>
                <InputDate class="form-control" @bind-Value="_model.OccurredOn" />
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-link" @onclick="() => OnCancelled.InvokeAsync()">Cancel</button>
        </EditForm>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public int CreditCardAccountId { get; set; }

    [Parameter, EditorRequired]
    public int CurrentUserId { get; set; }

    [Parameter, EditorRequired]
    public List<Account> OtherAccounts { get; set; } = new();

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private FormModel _model = new();
    private string? _fromAccountError;

    private async Task HandleSubmitAsync()
    {
        _fromAccountError = null;
        if (_model.FromAccountId is null)
        {
            _fromAccountError = "Please select an account to pay from.";
            return;
        }

        await TransactionService.PayCreditCardAsync(_model.FromAccountId.Value, CreditCardAccountId, _model.Amount, _model.Description, _model.OccurredOn, CurrentUserId);
        await OnSaved.InvokeAsync();
    }

    private class FormModel
    {
        public int? FromAccountId { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0.01, double.MaxValue, ErrorMessage = "Amount must be greater than 0.")]
        public decimal Amount { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string Description { get; set; } = "";

        public DateOnly OccurredOn { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    }
}
