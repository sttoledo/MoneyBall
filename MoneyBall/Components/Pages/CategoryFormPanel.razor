@using MoneyBall.Data.Entities
@using MoneyBall.Services
@inject CategoryService CategoryService

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">@(Existing is null ? "Add Category" : "Edit Category")</h5>

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-2">
                <label>Name</label>
                <InputText class="form-control" @bind-Value="_model.Name" />
            </div>

            <div class="mb-2">
                <label>Monthly Budget (optional)</label>
                <InputNumber class="form-control" @bind-Value="_model.MonthlyBudget" />
            </div>

            <div class="mb-2 form-check">
                <InputCheckbox class="form-check-input" id="isBudgetExempt" @bind-Value="_model.IsBudgetExempt" />
                <label class="form-check-label" for="isBudgetExempt">Exclude from budgets</label>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-link" @onclick="() => OnCancelled.InvokeAsync()">Cancel</button>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public Category? Existing { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private FormModel _model = new();

    protected override void OnInitialized()
    {
        if (Existing is not null)
        {
            _model = new FormModel { Name = Existing.Name, MonthlyBudget = Existing.MonthlyBudget, IsBudgetExempt = Existing.IsBudgetExempt };
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (Existing is null)
        {
            await CategoryService.CreateCategoryAsync(_model.Name, _model.MonthlyBudget, _model.IsBudgetExempt);
        }
        else
        {
            await CategoryService.UpdateCategoryAsync(Existing.Id, _model.Name, _model.MonthlyBudget, _model.IsBudgetExempt);
        }

        await OnSaved.InvokeAsync();
    }

    private class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Range(0.01, double.MaxValue, ErrorMessage = "Budget must be greater than 0.")]
        public decimal? MonthlyBudget { get; set; }

        public bool IsBudgetExempt { get; set; }
    }
}
