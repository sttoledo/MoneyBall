@using MoneyBall.Data.Entities
@using MoneyBall.Services
@inject TransactionService TransactionService

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">@(_isEdit ? "Edit" : "Add") @Type</h5>

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-2">
                <label>Amount</label>
                <InputNumber class="form-control" @bind-Value="_model.Amount" />
            </div>

            <div class="mb-2">
                <label>Description</label>
                <InputText class="form-control" @bind-Value="_model.Description" />
            </div>

            <div class="mb-2">
                <label>Date</label>
                <InputDate class="form-control" @bind-Value="_model.OccurredOn" />
            </div>

            @if (Type == TransactionType.Expense)
            {
                <div class="mb-2">
                    <label>Category</label>
                    <InputSelect class="form-control" @bind-Value="_model.CategoryId">
                        <option value="">-- Select a category --</option>
                        @foreach (var category in Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </InputSelect>
                    @if (_categoryError is not null)
                    {
                        <div class="text-danger">@_categoryError</div>
                    }
                </div>
            }

            <button type="submit" class="btn btn-primary">Save</button>
            <button type="button" class="btn btn-link" @onclick="() => OnCancelled.InvokeAsync()">Cancel</button>
        </EditForm>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public TransactionType Type { get; set; }

    [Parameter, EditorRequired]
    public int AccountId { get; set; }

    [Parameter, EditorRequired]
    public int CurrentUserId { get; set; }

    [Parameter, EditorRequired]
    public List<Category> Categories { get; set; } = new();

    [Parameter]
    public TransactionEntry? Existing { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private bool _isEdit;
    private FormModel _model = new();
    private string? _categoryError;

    protected override void OnInitialized()
    {
        _isEdit = Existing is not null;
        if (Existing is not null)
        {
            _model = new FormModel
            {
                Amount = Existing.Amount,
                Description = Existing.Description,
                OccurredOn = Existing.OccurredOn,
                CategoryId = Existing.CategoryId
            };
        }
    }

    private async Task HandleSubmitAsync()
    {
        _categoryError = null;
        if (Type == TransactionType.Expense && _model.CategoryId is null)
        {
            _categoryError = "Please select a category.";
            return;
        }

        if (_isEdit)
        {
            await TransactionService.UpdateTransactionAsync(Existing!.Id, _model.Amount, _model.Description, _model.OccurredOn, _model.CategoryId);
        }
        else if (Type == TransactionType.Deposit)
        {
            await TransactionService.AddDepositAsync(AccountId, _model.Amount, _model.Description, _model.OccurredOn, CurrentUserId);
        }
        else
        {
            await TransactionService.AddExpenseAsync(AccountId, _model.CategoryId!.Value, _model.Amount, _model.Description, _model.OccurredOn, CurrentUserId);
        }

        await OnSaved.InvokeAsync();
    }

    private class FormModel
    {
        [System.ComponentModel.DataAnnotations.Range(0.01, double.MaxValue, ErrorMessage = "Amount must be greater than 0.")]
        public decimal Amount { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string Description { get; set; } = "";

        public DateOnly OccurredOn { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        public int? CategoryId { get; set; }
    }
}
